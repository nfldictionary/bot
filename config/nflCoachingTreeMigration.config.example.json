{
  "sourceBaseUrl": "https://coaching-tree.app",
  "targetGitRepoUrl": "https://github.com/<owner>/<repo>.git",
  "targetGitBranch": "main",
  "targetRepoPath": "/absolute/path/to/<repo>",
  "localDataRoot": "/absolute/path/to/nfl-coaching-tree-data",
  "canonicalDataDir": "data/nfl-coaching-tree/canonical",
  "stagingDataDir": "data/nfl-coaching-tree/staging",
  "rawSnapshotDir": "/absolute/path/to/nfl-coaching-tree-data/raw/coaching-tree-app",
  "cacheDir": "/absolute/path/to/nfl-coaching-tree-data/cache/coaching-tree-app",
  "runLogDir": "/absolute/path/to/nfl-coaching-tree-data/logs",
  "exportDir": "/absolute/path/to/nfl-coaching-tree-data/exports",
  "backupDir": "/absolute/path/to/nfl-coaching-tree-data/backups",
  "concurrency": 2,
  "requestDelayMs": 1000,
  "retryLimit": 3,
  "timeoutMs": 30000,
  "methodologyVersion": "nfl-coaching-tree-v1",
  "scriptVersion": "0.1.0",
  "writeRawSnapshots": true,
  "writeStagingData": true,
  "writeCanonicalData": true,
  "commitEligibleCanonicalData": true
}
